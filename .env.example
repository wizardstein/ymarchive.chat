# Copy to .env.local for local dev. On Vercel, set these in
# Project Settings → Environment Variables.

# Resend API key — https://resend.com → API Keys
RESEND_API_KEY=

# Where feedback messages should be delivered.
FEEDBACK_TO_EMAIL=adelin.cavasi+ymarchive@gmail.com

# Verified sender in Resend. For local dev / quick start you can use
# "onboarding@resend.dev" — that only delivers to the Resend account
# owner's own email. For production, verify your own domain and use
# something like "YM Archive <no-reply@yourdomain.com>".
FEEDBACK_FROM_EMAIL=onboarding@resend.dev
